# =====================================================
# MeetingActionAgent - Environment Variables Template
# =====================================================
# Copy this file to .env and fill in your real values
# cp .env.example .env
# =====================================================

# Azure AI Foundry (REQUIRED)
AZURE_API_KEY=your_azure_openai_api_key_here
AZURE_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_MODEL=gpt-4.1-mini
AZURE_API_VERSION=2024-05-01-preview

# GitHub Integration (Optional)
GITHUB_PAT=ghp_your_personal_access_token_here
GITHUB_REPO=YourUsername/your-repo-name

# Notion Integration (Optional)
NOTION_TOKEN=ntn_your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# SendGrid Email (Optional)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=your_sender_email@example.com

# Microsoft Work IQ (Optional)
WORK_IQ_ENDPOINT=https://your-workiq-endpoint.microsoft.com
WORK_IQ_API_KEY=your_work_iq_key_here

# Jira Integration (Optional)
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-jira-email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=PROJ

# Azure Whisper Audio Transcription (Optional)
AZURE_WHISPER_DEPLOYMENT=whisper
